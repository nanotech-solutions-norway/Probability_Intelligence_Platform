# Optional Apache/Domeneshop routing for PIP Phase 2 internal API.
# Use only if the hosting environment supports mod_rewrite.
# The API remains read-only. Only GET is supported by PHP endpoint guards.

Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On

# Canonical pretty route:
# /api/v1/probability/football/fixture/982331?market=1X2
RewriteRule ^api/v1/probability/football/fixture/([0-9]+)/?$ api/v1/probability/football/fixture.php?fixture_id=$1 [QSA,L]
</IfModule>
