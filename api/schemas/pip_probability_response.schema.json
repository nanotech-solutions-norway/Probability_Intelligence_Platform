{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-ai.no/schemas/pip_probability_response.v1.schema.json",
  "title": "Atlas PIP Probability Response v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "platform",
    "platform_version",
    "fixture_id",
    "sport",
    "market",
    "model_version",
    "data_timestamp",
    "selection_probabilities",
    "compliance_mode",
    "execution_allowed",
    "audit"
  ],
  "properties": {
    "status": {"type": "string", "enum": ["ok", "degraded"]},
    "platform": {"type": "string", "const": "atlas_probability_intelligence_platform"},
    "platform_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "fixture_id": {"type": "integer", "minimum": 1},
    "sport": {"type": "string", "enum": ["football"]},
    "market": {"type": "string", "enum": ["1X2", "OVER_UNDER", "BTTS", "ASIAN_HANDICAP"]},
    "model_version": {"type": "string", "minLength": 3, "maxLength": 128},
    "data_timestamp": {"type": "string", "format": "date-time"},
    "selection_probabilities": {"type": "array", "minItems": 2, "maxItems": 10, "items": {"$ref": "#/$defs/selection_probability"}},
    "compliance_mode": {"type": "string", "const": "display_only"},
    "execution_allowed": {"type": "boolean", "const": false},
    "audit": {"$ref": "#/$defs/audit"},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "selection_probability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selection", "model_probability", "bookmaker_no_vig_probability", "fair_odds", "best_available_odds", "expected_value", "confidence_score", "recommendation"],
      "properties": {
        "selection": {"type": "string", "enum": ["home", "draw", "away", "over", "under", "yes", "no"]},
        "model_probability": {"type": "number", "minimum": 0, "maximum": 1},
        "bookmaker_no_vig_probability": {"type": "number", "minimum": 0, "maximum": 1},
        "fair_odds": {"type": "number", "exclusiveMinimum": 1},
        "best_available_odds": {"type": "number", "exclusiveMinimum": 1},
        "expected_value": {"type": "number", "minimum": -1, "maximum": 10},
        "confidence_score": {"type": "number", "minimum": 0, "maximum": 1},
        "recommendation": {"type": "string", "enum": ["BET", "WATCHLIST", "NO_BET"]}
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["calibration_version", "feature_version", "recommendation_policy_version", "source"],
      "properties": {
        "calibration_version": {"type": "string", "minLength": 1},
        "feature_version": {"type": "string", "minLength": 1},
        "recommendation_policy_version": {"type": "string", "minLength": 1},
        "source": {"type": "string", "enum": ["mock", "live", "backtest", "candidate"]}
      }
    }
  }
}
